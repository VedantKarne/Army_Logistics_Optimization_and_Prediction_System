# ============================================================
# Army ML Pipeline — .gitignore
# ============================================================

# ── Synthetic Data Generation (development-only, excluded by design) ─────────
# These scripts were used to build the synthetic test database.
# The real pipeline starts from feature_engineering.py onwards.
data_generation/

# ── Virtual Environment ──────────────────────────────────────
generate_data_env/
venv/
.venv/
env/
*.egg-info/

# ── Python Cache ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
# ── Logs (generated at runtime) ──────────────────────────────
*.log

# ── Large Generated Data / Exports ───────────────────────────
# The 275 MB SQL export (too large for GitHub)
exports/military_vehicle_health_export.sql
exports/database_stats.json
exports/verification_results.txt

# The Parquet feature matrix (generated by feature_engineering.py)
Army_ML_Pipeline_and_Files/vehicle_features.parquet

# ── Trained Model Artefacts ───────────────────────────────────
# These are generated by train_health_model.py — clone users run training themselves
Army_ML_Pipeline_and_Files/models/*.pkl
Army_ML_Pipeline_and_Files/models/*.npy
Army_ML_Pipeline_and_Files/models/*.zip

# Keep config JSON files (small, important for reproducibility)
!Army_ML_Pipeline_and_Files/models/*.json

# ── MLOps Run Logs ────────────────────────────────────────────
Army_ML_Pipeline_and_Files/reports/mlops/

# ── Temporary Directories ────────────────────────────────────
tmp/

# ── Internal Utility Scripts ─────────────────────────────────
# PDF generator — internal tool, not part of the pipeline
generate_pdf_docs.py

# ── IDE / OS Files ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ── Jupyter Notebooks (if any) ───────────────────────────────
.ipynb_checkpoints/

# ── Sensitive credentials ─────────────────────────────────────
# NOTE: DB passwords are hardcoded in scripts — contributors should
# update DB_CONFIG with their own credentials before running.
# Consider using a .env file and python-dotenv in production.
